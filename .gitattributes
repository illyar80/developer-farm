# Auto detect text files and perform LF normalization
* text=auto

# Python files
*.py text eol=lf
*.pyi text eol=lf
*.pyx text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Config files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# Git config
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files (ensure they're not modified)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.bz2 binary
*.7z binary

# Model files (binary, large)
*.bin binary
*.gguf binary
*.safetensors binary
*.pt binary
*.pth binary
*.onnx binary
*.h5 binary
*.pkl binary
*.joblib binary

# Database files
*.db binary
*.sqlite binary
*.sqlite3 binary
