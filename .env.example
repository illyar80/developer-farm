# Ollama Configuration (локальные модели)
# ============================================

# Base URL для Ollama API
OLLAMA_BASE_URL=http://localhost:11434/v1

# Модель для Planning узла
OLLAMA_MODEL=qwen2.5-coder:3b-instruct

# Модель для Verification узла (по умолчанию использует OLLAMA_MODEL)
OLLAMA_VERIFIER_MODEL=qwen2.5-coder:3b-instruct

# Dashboard Configuration
# ========================
DASHBOARD_PORT=8081
DASHBOARD_HOST=0.0.0.0

# Legacy (не используется при работе с Ollama)
# ==============================================
# OPENROUTER_API_KEY=your-key-here
# OPENROUTER_MODEL=qwen/qwen3.7-max
# OPENROUTER_VERIFIER_MODEL=qwen/qwen3-32b
